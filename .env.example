# --- FLOWISE CONFIG ---
PORT=3000
DATABASE_TYPE=sqlite
DATABASE_PATH=/root/.flowise
APIKEY_PATH=/root/.flowise
LOG_LEVEL=debug

# Optional: Flowise Authentication
# FLOWISE_USERNAME=admin
# FLOWISE_PASSWORD=password

# Optional: External Integration Secrets
# OPENAI_API_KEY=your_key_here
# PINECONE_API_KEY=your_key_here

# --- PYTHON ENGINE CONFIG ---
ENGINE_PORT=8000
PYTHON_LOG_LEVEL=INFO
# Use 'host.docker.internal' for Mac to talk from engine to Flowise
FLOWISE_API_URL=http://flowise:3000/api/v1

# --- DOCKER SHARED ---
LOG_PATH=./logs